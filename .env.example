# ID-porten klient-ID
# Registrer en klient på https://samarbeid.digdir.no/
# Velg "OIDC-integrasjon", type "public" (ingen client_secret nødvendig)
IDPORTEN_CLIENT_ID=din-client-id-her

# Sett til "test" for å bruke ID-porten testmiljø (ver2)
# Sett til "prod" for produksjon (standard)
WENCHE_ENV=prod
